<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- ========== 从 Spring Environment 读取（application.yml 默认值 + Nacos 覆盖） ========== -->
    <!--
        时序保证：NacosConfigEnvironmentPostProcessor 已调整为 HIGHEST_PRECEDENCE+15，
        在 LoggingApplicationListener（HIGHEST+20）初始化 logback 之前完成 Nacos 配置加载，
        因此以下 <springProperty> 均可读到 Nacos 中的配置值。
    -->
    <springProperty scope="context" name="appName"         source="spring.application.name"/>
    <springProperty scope="context" name="active"          source="spring.profiles.active"/>
    <springProperty scope="context" name="consoleEnable"   source="log.console.enable"   defaultValue="true"/>
    <springProperty scope="context" name="aliyunlogEnable" source="log.aliyunlog.enable" defaultValue="false"/>
    <springProperty scope="context" name="logLevel"        source="log.level"            defaultValue="INFO"/>

    <!-- 阿里云 SLS 配置（来自 Nacos xzagent.yml） -->
    <springProperty scope="context" name="endpoint"        source="aliyun.log.endpoint"/>
    <springProperty scope="context" name="accessKeyId"     source="aliyun.log.accessKeyId"/>
    <springProperty scope="context" name="accessKeySecret" source="aliyun.log.accessKeySecret"/>
    <springProperty scope="context" name="project"         source="aliyun.log.project"/>
    <springProperty scope="context" name="logStore"        source="aliyun.log.logStore"/>
    <springProperty scope="context" name="topic"           source="aliyun.log.topic"/>
    <!-- source 优先取 Nacos 配置，未配置则降级为 main() 预设的本机 IP -->
    <springProperty scope="context" name="source"          source="aliyun.log.source" defaultValue="${app.local.ip:-unknown}"/>

    <!-- ========== 控制台 Appender ========== -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <!-- 格式：时间 线程 级别 [应用名,traceId,spanId] logger - 消息 -->
            <!-- traceId/spanId 占位，接入 Micrometer Tracing 后自动填充 -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %thread %-5level [${appName},%X{traceId:-},%X{spanId:-}] %logger{40} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ========== 阿里云 SLS Appender ========== -->
    <appender name="ALIYUN_LOG" class="com.aliyun.openservices.log.logback.LoghubAppender">
        <!-- 账号及网络配置 -->
        <endpoint>${endpoint}</endpoint>
        <accessKeyId>${accessKeyId}</accessKeyId>
        <accessKeySecret>${accessKeySecret}</accessKeySecret>
        <!-- SLS 项目配置 -->
        <project>${project}</project>
        <logStore>${logStore}</logStore>
        <topic>${topic}</topic>
        <source>${source}</source>

        <!-- 发送性能调优 -->
        <totalSizeInBytes>104857600</totalSizeInBytes>
        <maxBlockMs>60000</maxBlockMs>
        <ioThreadCount>8</ioThreadCount>
        <batchSizeThresholdInBytes>524288</batchSizeThresholdInBytes>
        <batchCountThreshold>4096</batchCountThreshold>
        <lingerMs>2000</lingerMs>
        <retries>10</retries>
        <baseRetryBackoffMs>100</baseRetryBackoffMs>
        <maxRetryBackoffMs>100</maxRetryBackoffMs>

        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%d %thread %-5level [${appName},%X{traceId:-},%X{spanId:-}] %logger{40} %message %exception{10}</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <timeFormat>yyyy-MM-dd'T'HH:mmZ</timeFormat>
        <timeZone>Asia/Shanghai</timeZone>
    </appender>

    <!-- ========== 降噪配置 ========== -->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>
    <logger name="com.alibaba.nacos"              level="WARN"/>
    <logger name="org.springframework"            level="INFO"/>
    <logger name="org.apache.http.impl.conn.Wire" level="WARN"/>

    <!-- ========== Root Logger ========== -->
    <!--
        Logback 1.5.x 不支持 <if> 嵌套在 <root> 内部。
        解决方案：先声明 root 设置 level，再用顶层 <if> 按需追加 appender。
        多次声明 <root> 会累加 appender，不会重置 level。
    -->
    <root level="${logLevel}"/>

    <if condition='property("consoleEnable").contains("true")'>
        <then>
            <root>
                <appender-ref ref="CONSOLE_PLAIN"/>
            </root>
        </then>
    </if>

    <if condition='property("aliyunlogEnable").contains("true")'>
        <then>
            <root>
                <appender-ref ref="ALIYUN_LOG"/>
            </root>
        </then>
    </if>

</configuration>
